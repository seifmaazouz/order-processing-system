{
  "LABEL": {
    "name": "invalid-title",
    "color": "ff0000"
  },
  "CHECKS": {
    "regexp": "^(feat|fix|chore|docs|refactor|perf|test)(\\([a-zA-Z0-9_-]+\\))?: .+",
    "regexpFlags": "i",
    "ignoreLabels": ["bot", "invalid-title"]
  },
  "MESSAGES": {
