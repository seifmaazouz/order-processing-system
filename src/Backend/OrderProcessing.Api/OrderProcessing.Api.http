@OrderProcessingApi_HostAddress = http://localhost:8080
# Register customer
POST {{OrderProcessingApi_HostAddress}}/api/auth/register
Content-Type: application/json
Accept: application/json"

{
  "username": "mohamed.test11",
  "firstName": "Mohamed",
  "lastName": "Shal",
  "phoneNumber": "+201001234567",
  "email": "mohamed.test123@example.com",
  "password": "StrongPassword123!"
}

####
# Login customer
POST {{OrderProcessingApi_HostAddress}}/api/auth/login
Content-Type: application/json
Accept: application/json

{
  "username": "mohamed.test11",
  "password": "StrongPassword123!"
  
}
###
# Login admin to get token
