### Shopping Cart Endpoints (User)
@OrderProcessingApi_HostAddress = http://localhost:8080
@UserToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJtb2hhbWVkLnRlc3QxMSIsImh0dHA6Ly9zY2hlbWFzLm1pY3Jvc29mdC5jb20vd3MvMjAwOC8wNi9pZGVudGl0eS9jbGFpbXMvcm9sZSI6IkN1c3RvbWVyIiwianRpIjoiMjEyZmI5ODQtNmEyYy00OTVlLThjOWQtZWQ4ODVmZDVmMGUzIiwiZXhwIjoxNzY2ODA1MzY1LCJpc3MiOiJPcmRlclByb2Nlc3NpbmdBUEkiLCJhdWQiOiJPcmRlclByb2Nlc3NpbmdDbGllbnQifQ.8DDgv9dxROh9stVX2zuc8y9LzJ0dTSOQ_YGBMx4oXxM

# Add item to cart
POST {{OrderProcessingApi_HostAddress}}/api/shoppingcart/items
Authorization: Bearer {{UserToken}}
Content-Type: application/json

{
  "isbn": "978-1234567890",
  "quantity": 2,
  "unitPrice": 50.00
}

###
# Update item quantity
PUT {{OrderProcessingApi_HostAddress}}/api/shoppingcart/items/978-1234567890
Authorization: Bearer {{UserToken}}
Content-Type: application/json

{
  "isbn": "978-1234567890",
  "quantity": 3
}

###
# Remove item from cart
DELETE {{OrderProcessingApi_HostAddress}}/api/shoppingcart/items/978-1234567890
Authorization: Bearer {{UserToken}}

###
# Get cart details
GET {{OrderProcessingApi_HostAddress}}/api/shoppingcart
Authorization: Bearer {{UserToken}}

###
# Clear cart
DELETE {{OrderProcessingApi_HostAddress}}/api/shoppingcart
Authorization: Bearer {{UserToken}}

###
# Checkout cart
POST {{OrderProcessingApi_HostAddress}}/api/shoppingcart/checkout
Authorization: Bearer {{UserToken}}
Content-Type: application/json

{
  "cardNumber": "1234567890123456",
  "expiryDate": "2030-12-31"
}

### Shopping Cart Endpoints (Admin)
@AdminToken = <PASTE_ADMIN_JWT_TOKEN_HERE>

# Get admin's cart details
GET {{OrderProcessingApi_HostAddress}}/api/shoppingcart
Authorization: Bearer {{AdminToken}}

###
# Add item to admin cart
POST {{OrderProcessingApi_HostAddress}}/api/shoppingcart/items
Authorization: Bearer {{AdminToken}}
Content-Type: application/json

{
  "isbn": "978-9876543210",
  "quantity": 1,
  "unitPrice": 100.00
}

###
# Clear admin cart
DELETE {{OrderProcessingApi_HostAddress}}/api/shoppingcart
Authorization: Bearer {{AdminToken}}

###
# Checkout admin cart
POST {{OrderProcessingApi_HostAddress}}/api/shoppingcart/checkout
Authorization: Bearer {{AdminToken}}
Content-Type: application/json

{
  "cardNumber": "9876543210123456",
  "expiryDate": "2031-01-01"
}

###
